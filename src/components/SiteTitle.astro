---
// Custom site title with star wordmark and top-level nav: Home · Pit · Sheets · Docs.
// Overrides the default Starlight SiteTitle.
// Uses BASE_URL so links work both in dev (root) and on a project-page deploy.

const pathname = Astro.url.pathname
const baseRaw = import.meta.env.BASE_URL ?? "/"
const base = baseRaw.replace(/\/$/, "") // strip trailing slash for clean joins
const link = (path: string) => (path === "/" ? `${base}/` : `${base}${path}`)

const stripBase = (p: string) => {
  if (!base || !p.startsWith(base)) return p
  const trimmed = p.slice(base.length)
  return trimmed.startsWith("/") ? trimmed : "/" + trimmed
}
const route = stripBase(pathname)

const isActive = (prefix: string) => {
  if (prefix === "/") return route === "/" || route === ""
  return route === prefix || route.startsWith(prefix)
}
---

<div class="header-inner">
  <a href={link("/")} class="site-title" aria-label="Stardust home">
    <svg viewBox="0 0 24 24" aria-hidden="true" width="22" height="22" fill="currentColor">
      <path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4-6.2-4.5-6.2 4.5 2.4-7.4L2 9.4h7.6z"/>
    </svg>
    <span class="wordmark">Stardust</span>
  </a>
  <nav class="site-nav" aria-label="Primary">
    <a href={link("/")}        class:list={["nav-link", { active: isActive("/") }]}>Home</a>
    <a href={link("/pit/")}    class:list={["nav-link", { active: isActive("/pit/") }]}>Pit</a>
    <a href={link("/sheets/")} class:list={["nav-link", { active: isActive("/sheets/") }]}>Sheets</a>
    <a href={link("/docs/")}   class:list={["nav-link", { active: isActive("/docs/") }]}>Docs</a>
  </nav>
</div>

<style>
  .header-inner {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }
  .site-title {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
    font-size: 1.05rem;
    color: var(--sl-color-white);
    text-decoration: none;
    line-height: 1;
  }
  .site-title svg { color: var(--sl-color-accent); }
  .site-title:hover { opacity: 0.85; }

  .site-nav {
    display: flex;
    align-items: center;
    gap: 0.125rem;
  }
  .nav-link {
    color: var(--sl-color-gray-2);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    padding: 0.4rem 0.75rem;
    border-radius: 0.375rem;
    transition: color 120ms, background-color 120ms;
  }
  .nav-link:hover {
    color: var(--sl-color-white);
    background: var(--sl-color-gray-6);
  }
  .nav-link.active {
    color: var(--sl-color-white);
    background: var(--sl-color-gray-6);
  }

  @media (max-width: 50rem) {
    .wordmark { display: none; }
    .header-inner { gap: 0.75rem; }
    .nav-link { padding: 0.4rem 0.5rem; font-size: 0.825rem; }
  }
</style>
