---
// Custom site title with star wordmark and top-level nav: Home · Pit · Sheets · Docs.
// Overrides the default Starlight SiteTitle.
const pathname = Astro.url.pathname

// Match by URL prefix so any nested page highlights the right top-level nav.
const isActive = (prefix: string) => {
  if (prefix === "/") return pathname === "/"
  return pathname === prefix || pathname.startsWith(prefix + "/") || pathname === prefix.slice(0, -1)
}
---

<div class="header-inner">
  <a href="/" class="site-title" aria-label="Stardust home">
    <svg viewBox="0 0 24 24" aria-hidden="true" width="22" height="22" fill="currentColor">
      <path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4-6.2-4.5-6.2 4.5 2.4-7.4L2 9.4h7.6z"/>
    </svg>
    <span class="wordmark">Stardust</span>
  </a>
  <nav class="site-nav" aria-label="Primary">
    <a href="/"        class:list={["nav-link", { active: isActive("/") }]}>Home</a>
    <a href="/pit/"    class:list={["nav-link", { active: isActive("/pit/") }]}>Pit</a>
    <a href="/sheets/" class:list={["nav-link", { active: isActive("/sheets/") }]}>Sheets</a>
    <a href="/docs/"   class:list={["nav-link", { active: isActive("/docs/") }]}>Docs</a>
  </nav>
</div>

<style>
  .header-inner {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }
  .site-title {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
    font-size: 1.05rem;
    color: var(--sl-color-white);
    text-decoration: none;
    line-height: 1;
  }
  .site-title svg { color: var(--sl-color-accent); }
  .site-title:hover { opacity: 0.85; }

  .site-nav {
    display: flex;
    align-items: center;
    gap: 0.125rem;
  }
  .nav-link {
    color: var(--sl-color-gray-2);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    padding: 0.4rem 0.75rem;
    border-radius: 0.375rem;
    transition: color 120ms, background-color 120ms;
  }
  .nav-link:hover {
    color: var(--sl-color-white);
    background: var(--sl-color-gray-6);
  }
  .nav-link.active {
    color: var(--sl-color-white);
    background: var(--sl-color-gray-6);
  }

  /* On small screens, hide the wordmark and tighten spacing so the 4 nav links fit. */
  @media (max-width: 50rem) {
    .wordmark { display: none; }
    .header-inner { gap: 0.75rem; }
    .nav-link { padding: 0.4rem 0.5rem; font-size: 0.825rem; }
  }
</style>
